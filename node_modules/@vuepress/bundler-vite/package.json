{
  "name": "@vuepress/bundler-vite",
  "version": "2.0.0-rc.28",
  "description": "Bundler vite package of VuePress",
  "keywords": [
    "bundler",
    "vite",
    "vuepress",
    "vuepress-bundler"
  ],
  "homepage": "https://github.com/vuepress",
  "bugs": {
    "url": "https://github.com/vuepress/core/issues"
  },
  "license": "MIT",
  "author": "meteorlxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/core.git"
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./client.d.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "autoprefixer": "^10.4.27",
    "connect-history-api-fallback": "^2.0.0",
    "postcss": "^8.5.8",
    "postcss-load-config": "^6.0.1",
    "rolldown": "^1.0.0-rc.12",
    "vite": "^8.0.3",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "@vuepress/bundlerutils": "2.0.0-rc.28",
    "@vuepress/core": "2.0.0-rc.28",
    "@vuepress/client": "2.0.0-rc.28",
    "@vuepress/shared": "2.0.0-rc.28",
    "@vuepress/utils": "2.0.0-rc.28"
  },
  "devDependencies": {
    "@types/connect-history-api-fallback": "^1.5.4"
  },
  "tsdown": {
    "dts": true,
    "entry": "./src/index.ts",
    "fixedExtension": false,
    "format": "esm",
    "target": "es2023",
    "tsconfig": "../../tsconfig.dts.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist"
  }
}