{
    "name": "perry/perry",
    "description": "Cross-platform UI abstraction and build system inspired by Perry-TS",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "pestphp/pest": "^3.8",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Perry\\": "src/"
        },
        "classmap": [
            "src/IR/Node.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Perry\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/perry"
    ],
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
